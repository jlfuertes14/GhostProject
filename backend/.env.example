# AI Flood Infrastructure Planning Platform — Backend Environment Variables
# Copy this file to .env and update values as needed.

# Model Paths
DELAY_MODEL_PATH=./model_artifacts/xgb_delay_model.json
BUDGET_MODEL_PATH=./model_artifacts/xgb_budget_model.json
ENCODER_PATH=./model_artifacts/label_encoders.joblib

# Database and Data Paths
DB_PATH=./flood_projects.duckdb
CSV_DATA_PATH=../data/dpwh_flood_control_projects.csv

# Security & CORS
# Comma-separated list of allowed origins (e.g. your Vercel deployment URL)
ALLOWED_ORIGINS=http://localhost:3000,https://your-project.vercel.app
